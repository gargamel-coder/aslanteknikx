/* ── DO/DONT ─────────────────────────────────────────────── */
.do-dont { display: flex; gap: 6px; margin: 4px 0; }
.do-box, .dont-box { flex: 1; border-radius: 5px; overflow: hidden; }
.do-head { background: var(--hijau); color: white; padding: 4px 7px; font-weight: 700; font-size: 9px; }
.dont-head { background: var(--merah); color: white; padding: 4px 7px; font-weight: 700; font-size: 9px; }
.do-item, .dont-item { padding: 3px 7px; font-size: 8.5px; border-bottom: 0.3px solid #ddd; line-height: 1.35; }
.do-item { background: var(--hijau-bg); }
.dont-item { background: var(--merah-bg); }
.do-item::before { content: "✓ "; color: var(--hijau); font-weight: 700; }
.dont-item::before { content: "✗ "; color: var(--merah); font-weight: 700; }

/* ── BUTTONS ─────────────────────────────────────────────── */
.no-print {
  position: fixed; bottom: 20px; right: 20px; z-index: 999;
  display: flex; flex-direction: column; gap: 8px; align-items: flex-end;
}
.btn {
  background: var(--biru-tua); color: white;
  border: none; padding: 11px 20px; border-radius: 8px;
  cursor: pointer; font-size: 13px; font-weight: 700;
  box-shadow: 0 4px 14px rgba(0,0,0,0.3);
  display: flex; align-items: center; gap: 8px;
}
.btn:hover { background: var(--biru); }
.btn.loading { opacity: 0.7; cursor: wait; }
#progress-bar {
  position: fixed; top: 0; left: 0; height: 3px;
  background: var(--emas); width: 0;
  transition: width 0.3s; z-index: 9999;
  display: none;
}

/* ── PAGE NUMBER ─────────────────────────────────────────── */
.page-footer {
  position: absolute; bottom: 6mm; left: 13mm; right: 13mm;
  display: flex; justify-content: space-between;
  font-size: 7.5px; color: #aaa;
}
</style>
