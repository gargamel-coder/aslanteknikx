  border-radius: 5px;
  padding: 7px 9px;
  font-size: 9.5px;
  line-height: 1.45;
  margin: 6px 0;
}
.info-box.green { background: var(--hijau-bg); border-color: var(--hijau); }
.info-box.red   { background: var(--merah-bg); border-color: var(--merah); }
.info-box.gold  { background: #FFF8E1; border-color: var(--emas); }
.info-box.quote {
  font-style: italic;
  color: var(--biru-tua);
  border-color: var(--biru);
}

.warning-box {
  background: var(--merah-bg);
  border: 1px solid var(--merah);
  border-radius: 5px;
  padding: 7px 9px;
  font-size: 9.5px;
  margin: 6px 0;
}
.warning-box::before { content: "⚠ PERHATIAN: "; color: var(--merah); font-weight: 700; }

/* ── TABLES ──────────────────────────────────────────────── */
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 9px;
  margin: 4px 0;
}
th {
  padding: 5px 5px;
  text-align: left;
  font-weight: 700;
  font-size: 9px;
}
td {
  padding: 4px 5px;
  vertical-align: top;
}
tr:nth-child(even) td { background: #F5F5F5; }

.tbl-blue th  { background: var(--biru-tua); color: white; }
.tbl-red  th  { background: #B71C1C;          color: white; }
.tbl-green th { background: #1B5E20;          color: white; }
.tbl-grid td, .tbl-grid th { border: 0.3px solid #BBDEFB; }
.tbl-grid.red td, .tbl-grid.red th { border-color: #FFCDD2; }
.tbl-grid.green td, .tbl-grid.green th { border-color: #A5D6A7; }
tr:nth-child(even) td.no-stripe { background: inherit; }

/* ── STEPS ───────────────────────────────────────────────── */
.step { display: flex; align-items: flex-start; margin: 4px 0; gap: 7px; }
.step-num {
  min-width: 20px; height: 20px;
