<div id="progress-bar"></div>

<div class="no-print">
  <button class="btn" id="downloadBtn" onclick="downloadPDF()">
    ⬇ Download PDF
  </button>
  <button class="btn" style="background:#37474F;font-size:11px" onclick="window.print()">
    Cetak
  </button>
</div>

<script>
function downloadPDF() {
  const btn = document.getElementById('downloadBtn');
  const bar = document.getElementById('progress-bar');
  btn.classList.add('loading');
  btn.textContent = '⏳ Memproses...';
  bar.style.display = 'block';
  bar.style.width = '30%';

  const element = document.body;
  const opt = {
    margin:       [10, 11, 10, 11],
    filename:     'Panduan-Saku-Aslan-Teknik.pdf',
    image:        { type: 'jpeg', quality: 0.96 },
    html2canvas:  { scale: 2, useCORS: true, logging: false },
    jsPDF:        { unit: 'mm', format: 'a5', orientation: 'portrait' },
    pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
  };

  bar.style.width = '60%';

  html2pdf().set(opt).from(element).save()
    .then(() => {
      bar.style.width = '100%';
      setTimeout(() => {
        btn.classList.remove('loading');
        btn.innerHTML = '✓ Selesai — Download Lagi';
        bar.style.display = 'none';
        bar.style.width = '0';
      }, 800);
    })
    .catch(() => {
      btn.classList.remove('loading');
      btn.innerHTML = '⬇ Download PDF';
      bar.style.display = 'none';
    });
}
</script>

