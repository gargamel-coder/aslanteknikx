h2 { font-size: 11px; }
h3 { font-size: 10.5px; }
p  { font-size: 10px; line-height: 1.45; }

/* ── HEADER BOXES ────────────────────────────────────────── */
.bab-header {
  background: var(--biru-tua);
  color: white;
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 11.5px;
  font-weight: 700;
  margin-bottom: 10px;
}
.bab-header.blue  { background: var(--biru); }
.bab-header.red   { background: #B71C1C; }
.bab-header.green { background: #1B5E20; }
.bab-header.orange{ background: #E65100; }

/* ── SECTION TITLE ───────────────────────────────────────── */
.section-title {
  font-size: 10.5px;
  font-weight: 700;
  color: var(--biru-tua);
