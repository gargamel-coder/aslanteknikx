}
.step-content { flex: 1; }
.step-title { font-weight: 700; font-size: 10px; line-height: 1.3; }
.step-desc { font-size: 8.5px; color: #555; margin-top: 1px; line-height: 1.3; }

/* ── CHECKLIST ───────────────────────────────────────────── */
.checklist { border-radius: 5px; overflow: hidden; margin: 4px 0; }
.checklist-header {
  background: var(--biru-muda);
  padding: 5px 8px;
