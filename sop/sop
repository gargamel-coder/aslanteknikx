/* ── RESET & BASE ─────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --biru-tua:  #0D47A1;
  --biru:      #1976D2;
  --biru-muda: #E3F2FD;
  --emas:      #F9A825;
  --merah:     #C62828;
  --hijau:     #2E7D32;
  --hijau-bg:  #E8F5E9;
  --abu:       #212121;
  --abu-muda:  #F5F5F5;
  --merah-bg:  #FFEBEE;
}

body {
  font-family: 'Segoe UI', Arial, sans-serif;
  font-size: 11px;
  color: var(--abu);
  background: #e0e0e0;
  line-height: 1.4;
}

/* ── PRINT SETUP ──────────────────────────────────────────── */
@media print {
  body { background: white; }
  .page { box-shadow: none; margin: 0; page-break-after: always; }
  .page:last-child { page-break-after: avoid; }
  .no-print { display: none; }
  @page { size: A5; margin: 12mm 13mm; }
}

/* ── PAGE LAYOUT ─────────────────────────────────────────── */
.page {
  width: 148mm;
  min-height: 210mm;
  background: white;
  margin: 8mm auto;
  padding: 12mm 13mm 14mm;
  box-shadow: 0 2px 12px rgba(0,0,0,0.18);
