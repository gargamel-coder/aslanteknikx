}

/* ── COMPARISON TABLE ────────────────────────────────────── */
.comp-table { width: 100%; border-collapse: collapse; font-size: 8.5px; }
.comp-table th { background: var(--biru-tua); color: white; padding: 5px; text-align: center; font-size: 9px; }
.comp-table td { padding: 4px 5px; border: 0.3px solid #BBDEFB; vertical-align: middle; }
.comp-table tr:nth-child(even) td { background: var(--biru-muda); }

/* ── HEARD FRAMEWORK ─────────────────────────────────────── */
.heard-row { display: flex; gap: 0; margin: 0; }
.heard-key {
